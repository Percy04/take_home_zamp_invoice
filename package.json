{
  "name": "ap-resolution-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.18.0",
    "npm": ">=11.12.1"
  },
  "scripts": {
    "dev": "vite",
    "dev:server": "tsx watch server/src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "verify:live": "tsx scripts/verify-live.ts",
    "build": "npm run typecheck && vite build && tsc -p tsconfig.server.json",
    "start": "node dist/server/server/src/index.js"
  },
  "dependencies": {
    "@tanstack/react-query": "5.101.2",
    "better-sqlite3": "12.11.1",
    "decimal.js": "10.6.0",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "multer": "2.2.0",
    "pdf-lib": "1.17.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router-dom": "7.18.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/better-sqlite3": "7.6.13",
    "@types/express": "5.0.6",
    "@types/multer": "2.2.0",
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/supertest": "7.2.0",
    "@vitejs/plugin-react": "6.0.3",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "jsdom": "29.1.1",
    "prettier": "3.9.5",
    "supertest": "7.2.2",
    "tsx": "4.23.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  }
}
