# Default local/test mode. This uses committed recordings and consumes no provider credits.
PROVIDER_MODE=recorded
MAPPING_PROVIDER=openai
PORT=3000
RUNTIME_DIR=data/runtime
ALLOW_DEMO_RESET=true
DEV_CORS_ORIGIN=http://localhost:5173

# Required only when PROVIDER_MODE=live.
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_KEY=

# Choose one live mapper with MAPPING_PROVIDER=openai|gemini.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
